###
@ACCESS_TOKEN=YOUR_ACCESS_TOKEN
@PROJECT_ID=YOUR_PROJECT_ID
@MODEL=gemini-3-flash

@ENDPOINT=daily-cloudcode-pa.sandbox.googleapis.com
# @ENDPOINT=autopush-cloudcode-pa.sandbox.googleapis.com
# @ENDPOINT=cloudcode-pa.googleapis.com

### ================================
### Stream Generate Content (Gemini CLI / Antigravity)
### ================================

POST https://{{ENDPOINT}}/v1internal:streamGenerateContent?alt=sse
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json
Accept: text/event-stream
User-Agent: antigravity/1.18.4 darwin/arm64

{
  "project": "{{PROJECT_ID}}",
  "model": "{{MODEL}}",
  "request": {
    "contents": [
      {
        "role": "user",
        "parts": [
          { "text": "hi, create me a file with name abc.txt in current parent folder." }
        ]
      }
    ],
    "systemInstruction": {
      "role": "user",
      "parts": [
        { "text": "you are Nam, coding assistant" }
      ]
    },
    "generationConfig": {
      "temperature": 0.7,
      "maxOutputTokens": 1024
    }
  }
}

### ================================
### Antigravity (Agent mode)
### ================================

POST https://{{ENDPOINT}}/v1internal:streamGenerateContent?alt=sse
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json
Accept: text/event-stream
User-Agent: antigravity/1.18.4 darwin/arm64

{
  "project": "{{PROJECT_ID}}",
  "model": "{{MODEL}}",
  "request": {
    "contents": [
      {
        "role": "user",
        "parts": [
          { "text": "Hi how are you" }
        ]
      }
    ],
    "systemInstruction": {
      "role": "user",
      "parts": [
        { "text": "You are an AI coding assistant." }
      ]
    },
    "generationConfig": {
      "temperature": 0.3,
      "maxOutputTokens": 2048,
      "thinkingConfig": {
        "includeThoughts": true,
        "thinkingLevel": "HIGH"
      }
    }
  },
  "requestType": "agent",
  "userAgent": "antigravity",
  "requestId": "agent-test-456"
}

### ================================
### With Tool Calling
### ================================

POST https://{{ENDPOINT}}/v1internal:streamGenerateContent?alt=sse
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json
Accept: text/event-stream
User-Agent: antigravity/1.18.4 darwin/arm64

{
  "project": "{{PROJECT_ID}}",
  "model": "{{MODEL}}",
  "request": {
    "contents": [
      {
        "role": "user",
        "parts": [
          { "text": "What is the weather in Hanoi?" }
        ]
      }
    ],
    "tools": [
      {
        "functionDeclarations": [
          {
            "name": "get_weather",
            "description": "Get weather by city",
            "parameters": {
              "type": "object",
              "properties": {
                "city": { "type": "string" }
              },
              "required": ["city"]
            }
          }
        ]
      }
    ],
    "toolConfig": {
      "functionCallingConfig": {
        "mode": "AUTO"
      }
    }
  }
}

### Request with tool result

POST https://{{ENDPOINT}}/v1internal:streamGenerateContent?alt=sse
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json
Accept: text/event-stream
User-Agent: antigravity/1.18.4 darwin/arm64

{
  "project": "{{PROJECT_ID}}",
  "model": "{{MODEL}}",
  "request": {
    "contents": [
      {
        "role": "user",
        "parts": [
          { "text": "What is the weather in Hanoi?" }
        ]
      },
      {
            "role": "model",
            "parts": [
              {
                "thoughtSignature": "EsMBCsABAb4+9vsYcXsP5S7jRvd+ZTOO29eiDixa0vW9UN8YTopSKoo2hq3es2gBJb6DngYYjcJi2eGkbBl7+jSB59peym2l/lW5NuOW69IMHg6WPZ8F3qdHOH/mLj6mQ1Zs8burKy5EVgiVYAkDWrKN4crJTUVD9NfiH/TkurWOF8yVWovs9q7IWAHVTtSULfTNrduVyBdb0h3HnKt67jktBvPDm9mwOCmuhR+a4bt+FYeVfkjrN+54krtZZQakH+nPqHV9",
                "functionCall": {
                  "name": "get_weather",
                  "args": {
                    "city": "Hanoi"
                  },
                  "id": "p59k7qas"
                }
              }
            ]
      },
      {
        "role": "user",
        "parts": [
          {
            "functionResponse": {
              "name": "get_weather",
              "response": {
                "temperature": 30,
                "condition": "Sunny"
              }
            }
          }
        ]
      }
    ],
    "tools": [
      {
        "functionDeclarations": [
          {
            "name": "get_weather",
            "description": "Get weather by city",
            "parameters": {
              "type": "object",
              "properties": {
                "city": { "type": "string" }
              },
              "required": ["city"]
            }
          }
        ]
      }
    ],
    "toolConfig": {
      "functionCallingConfig": {
        "mode": "AUTO"
      }
    }
  }
}
